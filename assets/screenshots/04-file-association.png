<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="675" viewBox="0 0 1200 675" role="img">
  <rect width="1200" height="675" fill="#eef2ff"/>
  <rect x="20" y="20" width="1160" height="635" rx="14" fill="#ffffff" stroke="#bfdbfe"/>
  <text x="50" y="90" font-size="40" fill="#1f2937" font-family="Arial, Helvetica, sans-serif">Substitua esta imagem pelo print da associacao no Windows</text>
  <text x="50" y="150" font-size="24" fill="#4b5563" font-family="Arial, Helvetica, sans-serif">Associe .docx, .xlsx e .pptx ao Google Suite Quick Open</text>
  <rect x="70" y="200" width="1060" height="360" fill="#dbeafe"/>
  <text x="130" y="290" font-size="32" fill="#1d4ed8" font-family="Arial, Helvetica, sans-serif">Preview do print</text>
  <text x="130" y="340" font-size="24" fill="#3b82f6" font-family="Arial, Helvetica, sans-serif">Cole seu print real aqui</text>
</svg>
